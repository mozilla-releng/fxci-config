{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>mozilla-releng/reps:renovate-preset.json5"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "datasourceTemplate": "docker",
      "managerFilePatterns": ["hook-templates/**/*.yml"],
      "matchStrings": [
        "image: (?<depName>\\S+):(?<currentValue>run-task-\\S+)@(?<currentDigest>\\S+)"
      ],
      "versioningTemplate": "regex:^run-task-v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$"
    }
  ]
}
